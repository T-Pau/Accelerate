description Hello World on C64
arguments --target c64-basic --symbol-map hello-world.sym -o hello-world.prg hello-world.s cbm.lib
file hello-world.s ../examples/hello-world-cbm.s
file cbm.lib ../share/lib/cbm.lib
file hello-world.prg {} hello-world-c64.prg
file hello-world.sym {} <inline>
